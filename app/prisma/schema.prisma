generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Roast Points (purchase-based, redeemable for Roast Card)
  pointBalance   Int @default(0)

  // Knowledge XP (lesson/trivia-based, drives rank)
  knowledgeXP    Int           @default(0)
  knowledgeRank  KnowledgeRank @default(COFFEE_LOVER)

  // Streak
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  streakShields Int       @default(0)
  lastLogDate   DateTime?

  // Relations
  accounts        Account[]
  sessions        Session[]
  brewLogs        BrewLog[]
  achievements    UserAchievement[]
  originStamps    OriginStamp[]
  userProgress    UserProgress[]
  communityLogs   CommunityLog[]

  @@index([email])
}

model BrewLog {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  logType      LogType
  shopName     String?
  drinkType    DrinkType?
  originCountry String?

  receiptUrl      String?
  receiptVerified Boolean @default(false)

  rating   Int?
  notes    String?

  pointsEarned Int
  bonusPoints  Int    @default(0)
  bonusReason  String?
  streakDay    Int

  aiFact String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, logType])
}

model OriginStamp {
  id         String   @id @default(cuid())
  userId     String
  country    String
  firstLogId String
  earnedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, country])
  @@index([userId])
}

model UserAchievement {
  id          String      @id @default(cuid())
  userId      String
  achievement Achievement
  earnedAt    DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievement])
  @@index([userId])
}

// Lesson system
model Module {
  id          String        @id @default(cuid())
  title       String
  description String
  emoji       String
  rankUnlock  KnowledgeRank
  order       Int
  lessons     Lesson[]
}

model Lesson {
  id        String     @id @default(cuid())
  moduleId  String
  title     String
  content   String     @db.Text
  order     Int
  questions Question[]
  progress  UserProgress[]

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
}

model Question {
  id          String        @id @default(cuid())
  lessonId    String?
  text        String
  options     String[]
  correctIdx  Int
  explanation String        @db.Text
  difficulty  KnowledgeRank
  isTrivia    Boolean       @default(false)
  triviaDate  DateTime?

  lesson   Lesson?        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  progress UserProgress[]

  @@index([isTrivia, triviaDate])
}

model UserProgress {
  id           String   @id @default(cuid())
  userId       String
  lessonId     String?
  questionId   String
  correct      Boolean
  knowledgeXP  Int
  answeredAt   DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson   Lesson?   @relation(fields: [lessonId], references: [id])
  question Question  @relation(fields: [questionId], references: [id])

  @@index([userId, lessonId])
}

// Community aggregate (updated on each local log)
model CommunityLog {
  id        String   @id @default(cuid())
  userId    String
  logId     String
  month     String   // "2026-03" format
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([month])
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Enums
enum LogType {
  DRINK_LOCAL
  DRINK_CHAIN
  BAG_LOCAL
  BAG_CHAIN
}

enum DrinkType {
  ESPRESSO
  AMERICANO
  LATTE
  CAPPUCCINO
  FLAT_WHITE
  COLD_BREW
  POUR_OVER
  CORTADO
  MACCHIATO
  MOCHA
  OTHER
}

enum KnowledgeRank {
  COFFEE_LOVER
  ENTHUSIAST
  SPECIALTY_DRINKER
  CONNOISSEUR
  BARISTA
}

enum Achievement {
  FIRST_LOG
  FIRST_LOCAL
  FIRST_BAG
  FIRST_VERIFIED
  STREAK_3
  STREAK_7
  STREAK_14
  STREAK_30
  LOCAL_5
  LOCAL_25
  LOCAL_100
  SHIELD_EARNED
  CHAIN_BREAKER
  ORIGINS_3
  ORIGINS_5
  ORIGINS_10
  MISSION_FIRST
  LESSON_FIRST
  TRIVIA_STREAK_7
  REACHED_ENTHUSIAST
  REACHED_SPECIALTY
  REACHED_CONNOISSEUR
  REACHED_BARISTA
  EARLY_BIRD
  NIGHT_OWL
  BAG_COLLECTOR
}
